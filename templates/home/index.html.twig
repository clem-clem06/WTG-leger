{% extends 'base.html.twig' %}

{% block title %}Accueil - WorkTogether Data Solutions{% endblock %}

{% block body %}
    {# SECTION HERO (Présentation) #}
    <div class="bg-dark text-white py-5 mb-5">
        <div class="container py-5 text-center">
            <h1 class="display-4 fw-bold mb-4">WorkTogether Data Solutions</h1>
            <p class="lead w-75 mx-auto mb-5">
                Spécialiste dans la gestion de datacenters de pointe. Nous vous offrons une connectivité ultrarapide, une redondance électrique absolue et une sécurité physique et électronique de premier plan pour héberger vos infrastructures critiques.
            </p>
            <a href="#offres" class="btn btn-primary btn-lg px-5">Voir nos offres</a>
        </div>
    </div>

    <div class="container mb-5">
        {# SECTION STATISTIQUES #}
        <div class="row text-center mb-5 g-4">
            <div class="col-md-4">
                <div class="card bg-light border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-muted">Infrastructures</h5>
                        <h2 class="display-5 fw-bold text-primary">{{ totalBaies }} Baies</h2>
                        <p class="mb-0">Hautement sécurisées</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-muted">Capacité Totale</h5>
                        <h2 class="display-5 fw-bold text-dark">{{ totalUnites }} U</h2>
                        <p class="mb-0">D'espace d'hébergement</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-white-50">Disponibilité</h5>
                        <h2 class="display-5 fw-bold">{{ unitesDispo }} U</h2>
                        <p class="mb-0">Restantes à la location</p>
                    </div>
                </div>
            </div>
        </div>

        {# SECTION OFFRES (Celle qu'on a fait avant) #}
        <div id="offres" class="text-center mb-5 pt-4">
            <h2 class="fw-bold">Nos offres de location</h2>
            <p class="text-muted">Choisissez la dimension qui correspond à votre projet.</p>
        </div>

        <div class="row justify-content-center g-4 mb-5">
            {% for offre in offres %}
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card h-100 shadow-sm text-center border-primary">
                        <div class="card-header bg-primary text-white py-3">
                            <h3 class="my-0 fw-normal fs-4">{{ offre.nom }}</h3>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title pricing-card-title fs-2">
                                {{ (offre.prixMensuel / 100)|number_format(2, ',', ' ') }} €<small class="text-muted fw-light fs-6"> / mois</small>
                            </h4>
                            <p class="text-muted small mb-4">
                                Soit {{ (offre.prixAnnuel / 100)|number_format(2, ',', ' ') }} € par an
                            </p>

                            <ul class="list-unstyled mt-3 mb-4">
                                {% if offre.nombreUnites > 1 %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unités incluses</li>
                                {% else %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unité incluse</li>
                                {% endif %}
                                <li class="mt-2 text-success">✓ Support 24/7</li>
                                <li>✓ Bande passante 10 Gbps</li>
                            </ul>

                            <a href="#" class="btn btn-lg btn-outline-primary mt-auto w-100">Choisir cette offre</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <p class="alert alert-info">Aucune offre disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# FOOTER BASIQUE #}
    <footer class="bg-dark text-white-50 py-4 text-center mt-auto">
        <div class="container">
            <p class="mb-0">&copy; 2026 WorkTogether Data Solutions. Tous droits réservés.</p>
        </div>
    </footer>
{% endblock %}
