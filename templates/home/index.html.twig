{% extends 'base.html.twig' %}

{% block title %}Accueil - WorkTogether Data Solutions{% endblock %}

{% block body %}
    <div class="bg-dark text-white py-5 mb-5">
        <div class="container py-5 text-center">
            <h1 class="display-4 fw-bold mb-4">WorkTogether Data Solutions</h1>
            <p class="lead w-75 mx-auto mb-5">
                Spécialiste dans la gestion de datacenters de pointe. Nous vous offrons une connectivité ultrarapide, une redondance électrique absolue et une sécurité physique et électronique de premier plan pour héberger vos infrastructures critiques.
            </p>
            <a href="#offres" class="btn btn-primary btn-lg px-5">Voir nos offres</a>
        </div>
    </div>

    <div class="container mb-5">

        <div class="row align-items-center mb-5 pb-5 border-bottom">
            <div class="col-lg-7">
                <h2 class="fw-bold mb-4">Comprendre nos infrastructures</h2>
                <p class="text-muted fs-5 mb-4">
                    Pour garantir la sécurité et la performance de vos équipements, nous utilisons des standards industriels précis. Mais qu'est-ce que cela signifie concrètement pour l'hébergement de vos serveurs ?
                </p>

                <div class="mb-4">
                    <h4 class="text-primary fw-bold">🗄️ Qu'est-ce qu'une Baie ?</h4>
                    <p class="text-muted">
                        Une baie (souvent appelée <em>rack</em>) est une grande armoire métallique sécurisée, climatisée et alimentée électriquement de manière redondante. Elle sert à empiler et organiser vos serveurs, routeurs et équipements de stockage. WorkTogether possède <strong>{{ totalBaies }} baies de dernière génération</strong> dans son datacenter.
                    </p>
                </div>

                <div>
                    <h4 class="text-primary fw-bold">📏 Qu'est-ce qu'une Unité (U) ?</h4>
                    <p class="text-muted">
                        L'Unité (notée "U") est la mesure standard de hauteur dans un datacenter. 1U équivaut à 1,75 pouce (environ 4,45 cm). Nos baies mesurent <strong>42U de hauteur</strong>. Cela vous permet de louer l'espace exact dont vous avez besoin : de 1U pour un petit serveur web, jusqu'à 42U (la baie complète) pour une grande infrastructure.
                    </p>
                </div>
            </div>

            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <div class="bg-light p-5 rounded-4 border shadow-sm">
                    <h3 class="fw-bold text-dark mb-3">Une flexibilité totale</h3>
                    <p class="text-muted mb-4">
                        Que vous soyez une Start-up ayant besoin d'un seul espace ou une PME nécessitant la moitié d'une armoire, nos formules s'adaptent à la taille de votre matériel physique.
                    </p>
                    <a href="#offres" class="btn btn-outline-primary w-100">Découvrir nos formules</a>
                </div>
            </div>
        </div>

        {# STATISTIQUES #}
        <div class="row text-center mb-5 g-4">
            <div class="col-md-4">
                <div class="card bg-light border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-muted">Infrastructures</h5>
                        <h2 class="display-5 fw-bold text-primary">{{ totalBaies }} Baies</h2>
                        <p class="mb-0">Hautement sécurisées</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-muted">Capacité Totale</h5>
                        <h2 class="display-5 fw-bold text-dark">{{ totalUnites }} Unité</h2>
                        <p class="mb-0">D'espace d'hébergement</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white border-0 shadow-sm h-100 py-3">
                    <div class="card-body">
                        <h5 class="text-white-50">Disponibilité</h5>
                        <h2 class="display-5 fw-bold">{{ unitesDispo }} Unité</h2>
                        <p class="mb-0">Restantes à la location</p>
                    </div>
                </div>
            </div>
        </div>

        {# OFFRES #}
        <div id="offres" class="text-center mb-5 pt-4">
            <h2 class="fw-bold">Nos offres de location</h2>
            <p class="text-muted">Choisissez la dimension qui correspond à votre projet.</p>
        </div>

        <div class="row justify-content-center g-4 mb-5">
            {% for offre in offres %}
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card h-100 shadow-sm text-center border-primary">
                        <div class="card-header bg-primary text-white py-3">
                            <h3 class="my-0 fw-normal fs-4">{{ offre.nom }}</h3>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title pricing-card-title fs-2">
                                {{ (offre.prixMensuel / 100)|number_format(2, ',', ' ') }} €<small class="text-muted fw-light fs-6"> / mois</small>
                            </h4>
                            <p class="text-muted small mb-4">
                                Soit {{ (offre.prixAnnuel / 100)|number_format(2, ',', ' ') }} € par an
                            </p>

                            <ul class="list-unstyled mt-3 mb-4">
                                {% if offre.nombreUnites > 1 %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unités incluses</li>
                                {% else %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unité incluse</li>
                                {% endif %}
                                <li class="mt-2 text-success">✓ Support 24/7</li>
                                <li>✓ Bande passante 10 Gbps</li>
                            </ul>

                            <a href="{{ path('app_cart_add', {'id': offre.id}) }}" class="btn btn-lg btn-outline-primary mt-auto w-100">Choisir cette offre</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <p class="alert alert-info">Aucune offre disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
