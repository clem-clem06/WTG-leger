{% extends 'base.html.twig' %}

{% block title %}Mon Panier - WorkTogether{% endblock %}

{% block body %}
    <div class="container py-5 mb-5">
        <h1 class="mb-4 fw-bold">Mon Panier</h1>

        {% if cart and cart.cartItems|length > 0 %}
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-hover align-middle mb-0 bg-white text-center">
                    <thead class="bg-light">
                    <tr>
                        <th class="text-start">Offre</th>
                        <th>Durée (Abonnement)</th>
                        <th>Quantité</th>
                        <th>Prix de l'abonnement</th>
                        <th>Total de la ligne</th>
                        <th>Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% set totalPanier = 0 %}

                    {% for item in cart.cartItems %}
                        {% set sousTotal = item.price * item.quantity %}
                        {% set totalPanier = totalPanier + sousTotal %}

                        <tr>
                            <td class="fw-bold text-primary text-start">{{ item.offre.nom }}</td>

                            {# COLONNE DURÉE (+ ET -) #}
                            <td>
                                <div class="d-flex align-items-center justify-content-center">
                                    <form action="{{ path('app_cart_update_duree', {'id': item.id, 'action': 'decrease'}) }}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary me-2 fw-bold" {% if item.dureeMois == 1 or item.dureeMois == 12 %}disabled{% endif %}>-</button>
                                    </form>

                                    <span class="badge bg-info text-dark fs-6" style="min-width: 80px;">
                                        {% if item.dureeMois >= 12 %}
                                            {% if item.dureeMois / 12 == 1 %}
                                                {{ item.dureeMois / 12 }} an
                                            {% else %}
                                                {{ item.dureeMois / 12 }} ans
                                            {% endif %}
                                        {% else %}
                                            {{ item.dureeMois }} mois
                                        {% endif %}
                                    </span>

                                    <form action="{{ path('app_cart_update_duree', {'id': item.id, 'action': 'increase'}) }}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary ms-2 fw-bold">+</button>
                                    </form>
                                </div>
                            </td>

                            {# COLONNE QUANTITÉ (+ ET -) #}
                            <td>
                                <div class="d-flex align-items-center justify-content-center">
                                    <form action="{{ path('app_cart_decrease', {'id': item.id}) }}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary me-2 fw-bold">-</button>
                                    </form>

                                    <span class="fs-5" style="min-width: 30px;">{{ item.quantity }}</span>

                                    <form action="{{ path('app_cart_increase', {'id': item.id}) }}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary ms-2 fw-bold">+</button>
                                    </form>
                                </div>
                            </td>

                            <td>{{ (item.price / 100)|number_format(2, ',', ' ') }} €</td>

                            <td class="fw-bold">{{ (sousTotal / 100)|number_format(2, ',', ' ') }} €</td>

                            <td>
                                <form action="{{ path('app_cart_remove', {'id': item.id}) }}" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Retirer
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot class="bg-light fw-bold">
                    <tr>
                        <td colspan="3" class="text-end">TOTAL À PAYER :</td>
                        <td colspan="2" class="fs-4 text-start">{{ (totalPanier / 100)|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    </tfoot>
                </table>
            </div>

            <div class="text-end mt-4">
                <a href="{{ path('app_checkout') }}" class="btn btn-lg btn-success px-5">Passer au paiement</a>
            </div>
        {% else %}
            <div class="text-center py-5 bg-light rounded shadow-sm">
                <h3 class="text-muted mb-4">Votre panier est vide.</h3>
                <a href="{{ path('app_home') }}#offres" class="btn btn-primary">Découvrir nos offres</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
