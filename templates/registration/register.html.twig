{% extends 'base.html.twig' %}

{% block title %}Inscription - WorkTogether{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/authenticator.js') }}" defer></script>
{% endblock %}

{% block body %}
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card shadow-sm p-4 border-0 bg-light">
                    <h1 class="h3 mb-4 fw-bold text-center">Inscription</h1>

                    {% if form_errors(registrationForm) %}
                        <div class="alert alert-danger">
                            {{ form_errors(registrationForm) }}
                        </div>
                    {% endif %}

                    {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_row(registrationForm.email, {
                            'label': 'Adresse Email',
                            'attr': {
                                'autofocus': true,
                                'class': 'email-field',
                                'type': 'text'
                            }
                        }) }}
                        <div id="email-feedback" class="form-text small mt-1"></div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.plainPassword.first) }}
                        <div id="password-strength" class="form-text small mt-1"></div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(registrationForm.plainPassword.second) }}
                        <div id="password-match" class="form-text small mt-1"></div>
                    </div>

                    <div class="mb-3 form-check mt-4">
                        {{ form_row(registrationForm.agreeTerms) }}
                    </div>

                    <button type="submit" id="btn-submit" class="btn btn-primary w-100 mt-3 py-2" disabled>
                        Créer mon compte
                    </button>

                    {{ form_end(registrationForm) }}

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-2">Déjà un compte ?</p>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary w-100 rounded-pill fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
