{% extends 'base.html.twig' %}

{% block title %}{{ offre.nom }}{% endblock %}

{% block body %}
<div class="container">
    <h1>{{ offre.nom }}</h1>
    <p>Unités: {{ offre.nombreUnites }}</p>
    <p>Prix mensuel: {{ offre.prixMensuel / 100 }}€</p>
    <p>Prix annuel: {{ offre.prixAnnuel / 100 }}€</p>
    <form action="{{ path('app_cart_add', {id: offre.id}) }}" method="post">
        <label for="quantity">Quantité:</label>
        <input type="number" id="quantity" name="quantity" value="1" min="1">
        <button type="submit" class="btn btn-success">Ajouter au panier</button>
    </form>
    <a href="{{ path('app_cart') }}" class="btn btn-secondary">Voir le panier</a>
</div>
{% endblock %}
