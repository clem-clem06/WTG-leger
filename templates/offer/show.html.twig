{% extends 'base.html.twig' %}

{% block title %}{{ offre.nom }} - WorkTogether{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/show.js') }}" defer></script>
{% endblock %}

{% block body %}
    <div class="container py-5 mb-5" id="offre-detail">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold text-primary mb-3">{{ offre.nom }}</h1>
                <p class="lead text-muted">Location de {{ offre.nombreUnites }} unité(s) dans nos baies hautement sécurisées.</p>
                <ul class="list-unstyled mt-4 fs-5">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Connexion Fibre très haut débit</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Alimentation redondante (Onduleurs + Groupes)</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Accès sécurisé 24/7</li>
                </ul>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <h3 class="fw-bold mb-4 text-center">Choisissez votre abonnement</h3>

                        {# 1. DÉBUT DU FORMULAIRE SYMFONY #}
                        {{ form_start(form, {'attr': {'id': 'offer-form'}}) }}

                        {# Le champ caché que Symfony va lire (et que le JS va remplir) #}
                        {{ form_widget(form.duree, {'id': 'input-duree-hidden'}) }}

                        {# ======================================================== #}
                        {# PARTIE VISUELLE #}
                        {# ======================================================== #}
                        <div class="row g-3 mb-4 position-relative">
                            <div class="col-6">
                                <input type="radio" class="btn-check" name="type_abonnement" id="radio-mensuel" autocomplete="off" checked>
                                <label class="btn btn-outline-primary w-100 p-3 h-100 d-flex flex-column align-items-center justify-content-center" for="radio-mensuel">
                                    <i class="bi bi-calendar-month fs-3 mb-2"></i>
                                    <span class="fw-bold">Mensuel</span>
                                    <small class="text-muted mt-1">{{ offre.prixMensuel|number_format(0, ',', ' ') }} € / mois</small>                                </label>
                            </div>
                            <div class="col-6">
                                <input type="radio" class="btn-check" name="type_abonnement" id="radio-annuel" autocomplete="off">
                                <label class="btn btn-outline-primary w-100 p-3 h-100 d-flex flex-column align-items-center justify-content-center position-relative" for="radio-annuel">
                                    <span class="badge bg-danger position-absolute top-0 start-50 translate-middle mt-2" style="font-size: 0.7rem;">2 MOIS OFFERTS</span>
                                    <i class="bi bi-calendar-star fs-3 mb-2 mt-2"></i>
                                    <span class="fw-bold">Annuel</span>
                                    <small class="text-muted mt-1">{{ (offre.prixMensuel * 10)|number_format(0, ',', ' ') }} € / an</small>
                                </label>
                            </div>
                        </div>
                        {# ======================================================== #}
                        {# PARTIE VISUELLE #}
                        {# ======================================================== #}
                        <div class="mb-4">
                            <label for="input-duree-display" class="fw-bold mb-2 text-dark">Durée d'engagement :</label>
                            <div class="input-group input-group-lg">
                                <input type="number" id="input-duree-display" class="form-control fw-bold" value="1" min="1">
                                <span class="input-group-text bg-light text-dark fw-semibold" id="addon-duree">mois</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 border mb-4">
                            <label for="input-quantite" class="fw-bold mb-0 text-dark">Unités :</label>
                            <div class="input-group flex-nowrap w-auto">
                                <button class="btn btn-outline-secondary bg-white fw-bold" type="button" id="btn-qty-minus">-</button>
                                {{ form_widget(form.quantite, {
                                    'id': 'input-quantite',
                                    'attr': {
                                        'class': 'form-control text-center fw-bold border-secondary',
                                        'min': '1'
                                    }
                                }) }}
                                <button class="btn btn-outline-secondary bg-white fw-bold" type="button" id="btn-qty-plus">+</button>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="fas fa-shopping-cart me-2"></i> Ajouter au panier
                            </button>
                        </div>

                        {# 2. FIN DU FORMULAIRE SYMFONY #}
                        {{ form_end(form) }}

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
