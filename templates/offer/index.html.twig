{% extends 'base.html.twig' %}

{% block title %}Offres{% endblock %}

{% block body %}
<div class="container">
    <h1>Nos Offres</h1>
    <div class="row">
        {% for offre in offres %}
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">{{ offre.nom }}</h5>
                    <p class="card-text">{{ offre.nombreUnites }} unités</p>
                    <p class="card-text">Prix mensuel: {{ offre.prixMensuel / 100 }}€</p>
                    <a href="{{ path('app_offer_show', {id: offre.id}) }}" class="btn btn-primary">Voir détails</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
