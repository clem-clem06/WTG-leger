{% extends 'base.html.twig' %}

{% block title %}Checkout{% endblock %}

{% block body %}
    <div class="container">
        <h1>Récapitulatif de commande</h1>
        <table class="table">
            <thead>
                <tr>
                    <th>Offre</th>
                    <th>Quantité</th>
                    <th>Prix</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart.cartItems %}
                <tr>
                    <td>{{ item.offre.nom }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ item.price / 100 }}€</td>
                    <td>{{ (item.price * item.quantity) / 100 }}€</td>
                </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Total</th>
                    <th>{% set total = 0 %}{% for item in cart.cartItems %}{% set total = total + (item.price * item.quantity) %}{% endfor %}{{ total / 100 }}€</th>
                </tr>
            </tfoot>
        </table>
        <form action="{{ path('app_checkout_process') }}" method="post">
            <h3>Informations de paiement (simulé)</h3>
            <label for="card_number">Numéro de carte:</label>
            <input type="text" id="card_number" name="card_number" placeholder="1234 5678 9012 3456" required>
            <button type="submit" class="btn btn-success">Payer</button>
        </form>
    </div>
{% endblock %}
