{% extends 'base.html.twig' %}

{% block title %}Checkout{% endblock %}

{% block body %}
    <div class="container">
        <h1>Récapitulatif de commande</h1>
        <table class="table">
            <thead>
                <tr>
                    <th>Offre</th>
                    <th>Quantité</th>
                    <th>Prix</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart.cartItems %}
                <tr>
                    <td>{{ item.offre.nom }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ item.price / 100 }}€</td>
                    <td>{{ (item.price * item.quantity) / 100 }}€</td>
                </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Total</th>
                    <th>{% set total = 0 %}{% for item in cart.cartItems %}{% set total = total + (item.price * item.quantity) %}{% endfor %}{{ total / 100 }}€</th>
                </tr>
            </tfoot>
        </table>
        <form action="{{ path('app_checkout_process') }}" method="post" id="payment-form">

            <div class="mb-3">
                <label class="form-label">Numéro de carte
                    <input type="text" name="cardNumber" class="form-control" placeholder="0000 0000 0000 0000" maxlength="19" required>
                </label>
            </div>

            <div class="row mb-4">
                <div class="col-6">
                    <label class="form-label">Expiration (MM/YY)
                        <input type="text" name="expDate" class="form-control" placeholder="12/28" maxlength="5" required>
                    </label>
                </div>
                <div class="col-6">
                    <label class="form-label">CVC
                        <input type="text" class="form-control" placeholder="123" maxlength="3" required>
                    </label>
                </div>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" name="saveCard" id="saveCard" value="1" checked>
                <label class="form-check-label text-muted small" for="saveCard">
                    Mémoriser cette carte de manière sécurisée
                </label>
            </div>

            <button type="submit" class="btn btn-success">Payer</button>
        </form>
    </div>
{% endblock %}
